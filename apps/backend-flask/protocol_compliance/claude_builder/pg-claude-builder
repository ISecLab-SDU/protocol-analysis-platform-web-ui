#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[pg-builder][%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*"
}

log_section() {
  log "========== $* =========="
}

log_file_preview() {
  local path="$1"
  local label="$2"
  local max_lines="${3:-120}"

  if [[ ! -f "$path" ]]; then
    log "$label missing at $path"
    return
  fi

  log "$label at $path ($(wc -c < "$path") bytes)"
  sed -n "1,${max_lines}p" "$path" | sed "s/^/[pg-builder][$label] /"
}

fail() {
  log "ERROR: $*"
  exit 1
}

HOST_UID="${PG_HOST_UID:-}"
HOST_GID="${PG_HOST_GID:-}"
WORKSPACE_DIR="${PG_BUILDER_WORKSPACE:-/workspace}"
OUT_DIR="${PG_BUILDER_OUT:-/out}"

cleanup_ownership() {
  if [[ -n "$HOST_UID" && -n "$HOST_GID" ]]; then
    chown -R "$HOST_UID:$HOST_GID" "$WORKSPACE_DIR" "$OUT_DIR" 2>/dev/null || true
  fi
}
trap cleanup_ownership EXIT

configure_claude() {
  local token="${ANTHROPIC_API_KEY:-${ANTHROPIC_AUTH_TOKEN:-}}"
  local api_key="${ANTHROPIC_API_KEY:-$token}"
  local auth_token="${ANTHROPIC_AUTH_TOKEN:-$token}"
  local base_url="${ANTHROPIC_BASE_URL:-}"

  [[ -n "$token" ]] || fail "ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN is required"
  [[ -n "$base_url" ]] || fail "ANTHROPIC_BASE_URL is required"

  mkdir -p /root/.claude
  cat > /root/.claude/settings.json <<EOF
{
  "env": {
    "ANTHROPIC_API_KEY": "${api_key}",
    "ANTHROPIC_AUTH_TOKEN": "${auth_token}",
    "ANTHROPIC_BASE_URL": "${base_url}",
    "IS_SANDBOX": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [],
    "deny": []
  }
}
EOF
  log "Claude Code settings written; credentials are not printed"
  log "Claude Code base URL is configured; credential values are redacted"
}

write_prompt() {
  cat > "$WORKSPACE_DIR/claude_builder_prompt.md" <<'EOF'
You are running inside a disposable Docker container for ProtocolGuard static analysis.

Your job is to compile the uploaded C/C++ protocol implementation and place LLVM build artefacts where the Flask backend expects them. Work autonomously by inspecting files, trying builds, reading errors, and fixing the build commands until the required artefacts exist. Do not ask the user questions.

The host backend reads your real Agent SDK typed stream, including tool-use
events, so you do not need to write progress files or print machine-readable
markers. Keep any explanatory text concise and focused on decisions and results.

Container facts:
- The current directory is `/workspace`.
- Source archives mounted in `/workspace` are extracted to `/workspace/project` before you start. Inspect the directory instead of assuming a specific project name.
- `/workspace/config.toml` and `/workspace/rule_config.json` are provided by Flask.
- The installed LLVM toolchain is LLVM/Clang 14. `gclang`, `gclang++`, `get-bc`, `llvm-dis-14`, `cmake`, `make`, `ninja`, `tree`, and `file` are available.
- Use `gclang`/`gclang++` so `get-bc` can extract bitcode.
- Prefer Debug builds with `-g -O0 -Xclang -disable-O0-optnone -fno-discard-value-names`.

Required final artefacts:
- `/workspace/program.bc`
- `/workspace/program.ll`
- `/workspace/build_log.txt`
- `/workspace/inputs/rules.json`
- `/workspace/inputs/config.toml`
- The compiled executable copied to `/workspace/program` when possible.
- Preserve or copy `.cf_*.json` files under the extracted source tree when they exist.

Recommended procedure:
1. Print a concise inventory with `pwd`, `ls -la /workspace`, and `tree -a -L 3 /workspace`.
2. Identify the actual project root by locating `CMakeLists.txt`, `configure`, `Makefile`, or other build files.
3. For CMake projects, create a clean build directory and run CMake with `gclang`/`gclang++`. Then run the build with verbose output and tee all output to `/workspace/build_log.txt`.
4. Run `get-bc` on the produced executable or linked binary. Copy the resulting `.bc` file to `/workspace/program.bc`, and run `llvm-dis-14 /workspace/program.bc -o /workspace/program.ll`.
5. Copy `rule_config.json` to `/workspace/inputs/rules.json` and `config.toml` to `/workspace/inputs/config.toml`.
6. Copy useful build outputs, `.db` files, callgraph reports, and function summaries back under `/workspace` without deleting the project directory.
7. Before exiting, verify the required files with `ls -la` and `file`.

Do not fabricate placeholder bitcode. If a required artefact cannot be produced, leave the full attempted command output in `/workspace/build_log.txt` and exit non-zero.
EOF
  log "Claude builder prompt written to $WORKSPACE_DIR/claude_builder_prompt.md"
  log "Claude builder prompt sha256: $(sha256sum "$WORKSPACE_DIR/claude_builder_prompt.md" | awk '{print $1}')"
  log_file_preview "$WORKSPACE_DIR/claude_builder_prompt.md" "prompt-preview" 80
}

log_workspace_inputs() {
  log_section "workspace inputs before Claude Code"
  log "Working directory: $(pwd)"
  log "Mounted workspace inventory"
  find "$WORKSPACE_DIR" -maxdepth 3 -mindepth 1 -printf '[pg-builder][workspace] %y %p\n' | sort
  log_file_preview "$WORKSPACE_DIR/config.toml" "config.toml" 200
  log_file_preview "$WORKSPACE_DIR/rule_config.json" "rule_config.json" 120
}

extract_source_archives() {
  log_section "source archive extraction"
  PG_BUILDER_WORKSPACE="$WORKSPACE_DIR" python3 - <<'PY'
import os
import tarfile
import zipfile
from pathlib import Path

workspace = Path(os.environ.get("PG_BUILDER_WORKSPACE", "/workspace"))
project_dir = workspace / "project"
ignored_names = {
    "build_log.txt",
    "claude_builder.log",
    "claude_builder_events.jsonl",
    "claude_builder_prompt.md",
    "config.toml",
    "rule_config.json",
}


def log(message: str) -> None:
    print(f"[pg-builder][archive] {message}", flush=True)


def is_within_directory(base: Path, candidate: Path) -> bool:
    try:
        candidate.resolve(strict=False).relative_to(base.resolve(strict=False))
        return True
    except ValueError:
        return False


def safe_extract_tar(archive: Path, destination: Path) -> None:
    with tarfile.open(archive, "r:*") as tar:
        for member in tar.getmembers():
            target = destination / member.name
            if not is_within_directory(destination, target):
                raise RuntimeError(f"unsafe tar member path: {member.name}")
            if member.issym() or member.islnk():
                link_target = Path(member.linkname)
                if not link_target.is_absolute():
                    link_target = target.parent / link_target
                if not is_within_directory(destination, link_target):
                    raise RuntimeError(f"unsafe tar link target: {member.name} -> {member.linkname}")
        tar.extractall(destination)


def safe_extract_zip(archive: Path, destination: Path) -> None:
    with zipfile.ZipFile(archive, "r") as zip_file:
        for member in zip_file.namelist():
            target = destination / member
            if not is_within_directory(destination, target):
                raise RuntimeError(f"unsafe zip member path: {member}")
        zip_file.extractall(destination)


def archive_kind(path: Path) -> str | None:
    if tarfile.is_tarfile(path):
        return "tar"
    if zipfile.is_zipfile(path):
        return "zip"
    return None


def candidate_archives() -> list[tuple[Path, str]]:
    candidates: list[tuple[Path, str]] = []
    for path in sorted(workspace.iterdir(), key=lambda item: item.name):
        if not path.is_file() or path.name in ignored_names:
            continue
        kind = archive_kind(path)
        if kind:
            candidates.append((path, kind))
    return candidates


archives = candidate_archives()
if not archives:
    log(f"No tar or zip source archives found in {workspace}")
    raise SystemExit(0)

project_dir.mkdir(parents=True, exist_ok=True)
for archive, kind in archives:
    size = archive.stat().st_size
    log(f"Extracting {kind} archive {archive} ({size} bytes) to {project_dir}")
    if kind == "tar":
        safe_extract_tar(archive, project_dir)
    elif kind == "zip":
        safe_extract_zip(archive, project_dir)

extracted = sorted(
    str(path.relative_to(project_dir))
    for path in project_dir.rglob("*")
    if path.is_file()
)[:120]
if extracted:
    for relative in extracted:
        log(f"extracted {relative}")
else:
    log("Archive extraction completed, but no regular files were found")
PY
}

run_claude() {
  log_workspace_inputs
  extract_source_archives
  log "Checking Claude Code CLI and Agent SDK"
  claude --version
  python3 - <<'PY'
import claude_agent_sdk
print(f"claude-agent-sdk {claude_agent_sdk.__version__}")
PY

  write_prompt
  log "Starting Claude builder agent through Agent SDK typed stream"
  set +e
  IS_SANDBOX=1 PG_CLAUDE_WORKSPACE="$WORKSPACE_DIR" python3 /usr/local/bin/pg_claude_builder_sdk.py \
    2>&1 | tee "$WORKSPACE_DIR/claude_builder.log"
  local claude_status="${PIPESTATUS[0]}"
  set -e
  log "Claude builder agent exited with status ${claude_status}"
  if [[ -f "$WORKSPACE_DIR/claude_builder_events.jsonl" ]]; then
    log_file_preview "$WORKSPACE_DIR/claude_builder_events.jsonl" "claude-sdk-events" 200
  else
    log "Claude SDK event stream was not persisted"
  fi
  return "$claude_status"
}

fallback_validation() {
  log_section "post-Claude artifact validation"
  mkdir -p "$WORKSPACE_DIR/inputs"
  if [[ -f "$WORKSPACE_DIR/rule_config.json" ]]; then
    cp "$WORKSPACE_DIR/rule_config.json" "$WORKSPACE_DIR/inputs/rules.json"
    log "[claude-artifact] copied $WORKSPACE_DIR/rule_config.json to $WORKSPACE_DIR/inputs/rules.json"
  fi
  if [[ -f "$WORKSPACE_DIR/config.toml" ]]; then
    cp "$WORKSPACE_DIR/config.toml" "$WORKSPACE_DIR/inputs/config.toml"
    log "[claude-artifact] copied $WORKSPACE_DIR/config.toml to $WORKSPACE_DIR/inputs/config.toml"
  fi

  [[ -f "$WORKSPACE_DIR/program.bc" ]] || fail "Missing $WORKSPACE_DIR/program.bc after Claude builder run"
  [[ -f "$WORKSPACE_DIR/program.ll" ]] || llvm-dis-14 "$WORKSPACE_DIR/program.bc" -o "$WORKSPACE_DIR/program.ll"
  [[ -f "$WORKSPACE_DIR/build_log.txt" ]] || cp "$WORKSPACE_DIR/claude_builder.log" "$WORKSPACE_DIR/build_log.txt"

  for artifact in \
    "$WORKSPACE_DIR/program.bc" \
    "$WORKSPACE_DIR/program.ll" \
    "$WORKSPACE_DIR/build_log.txt" \
    "$WORKSPACE_DIR/inputs/rules.json" \
    "$WORKSPACE_DIR/inputs/config.toml"; do
    if [[ -e "$artifact" ]]; then
      log "[claude-artifact] validated $artifact ($(wc -c < "$artifact") bytes)"
      file "$artifact" | sed 's/^/[pg-builder][artifact-file] /'
    else
      log "[claude-artifact] missing $artifact"
    fi
  done

  log "Final workspace snapshot"
  ls -la "$WORKSPACE_DIR"
  find "$WORKSPACE_DIR" -maxdepth 4 -type f \( -name 'program.bc' -o -name 'program.ll' -o -name 'build_log.txt' -o -name '*.db' -o -name '.cf_*.json' \) -print
}

main() {
  log "ProtocolGuard Claude builder started"
  configure_claude
  run_claude
  fallback_validation
  log "ProtocolGuard Claude builder completed"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
